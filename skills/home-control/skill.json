{
  "id": "home-control",
  "name": "Home Control",
  "description": "Control smart home devices via natural language. Supports Home Assistant, Philips Hue, Tuya/Smart Life, Google Home/Nest, LG TV, and Bosch Home Connect.",
  "version": "2.0.0",
  "connectors": [
    "home-assistant-mcp",
    "hue-mcp",
    "tuya-mcp",
    "google-home-mcp"
  ],
  "problem": {
    "statement": "Users want to control all their smart home devices using natural language across multiple providers.",
    "context": "Home has 6 providers: Home Assistant (core hub), Philips Hue (lights), Tuya/Smart Life (IoT), Google Home/Nest (thermostats), LG TV (WebOS), Bosch Home Connect (oven).",
    "goals": [
      "Control any device with natural language",
      "Query device states across all providers",
      "List rooms and devices",
      "Execute commands immediately without confirmations"
    ]
  },
