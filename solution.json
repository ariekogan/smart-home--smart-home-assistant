{
  "id": "smart-home-assistant",
  "name": "Smart Home Assistant",
  "version": "1.0.0",
  "description": "Smart home control.",
  "skills": [
    {
      "id": "connect-my-home",
      "name": "Connect My Home",
      "role": "gateway",
      "entry_channels": [],
      "connectors": [
        "home-assistant-mcp",
        "hue-mcp",
        "tuya-mcp",
        "google-home-mcp"
      ]
    },
    {
      "id": "home-control",
      "name": "Home Control",
      "role": "worker",
      "entry_channels": [
        "chat",
        "dashboard",
        "voice"
      ],
      "connectors": [
        "home-assistant-mcp",
        "hue-mcp",
        "tuya-mcp",
        "google-home-mcp"
      ],
      "ui_capable": true
    }
  ],
  "platform_connectors": [
    {
      "id": "home-assistant-mcp",
      "required": true,
      "ui_capable": true,
      "used_by": [
        "connect-my-home",
        "home-control"
      ]
    },
    {
      "id": "hue-mcp",
      "required": false,
      "used_by": [
        "connect-my-home",
        "home-control"
      ]
    },
    {
      "id": "tuya-mcp",
      "required": false,
      "used_by": [
        "connect-my-home",
        "home-control"
      ]
    },
    {
      "id": "google-home-mcp",
      "required": false,
      "used_by": [
        "connect-my-home",
        "home-control"
      ]
    }
  ],
  "identity": {
    "actor_types": [
      {
        "key": "homeowner",
        "label": "Homeowner",
        "default_channel": "chat"
      }
    ],
    "admin_roles": [
      "homeowner"
    ],
    "default_actor_type": "homeowner"
  },
  "routing": {
    "chat": {
      "default_skill": "home-control"
    },
    "dashboard": {
      "default_skill": "home-control"
    },
    "voice": {
      "default_skill": "home-control"
    }
  }
}