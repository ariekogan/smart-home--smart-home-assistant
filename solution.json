{
  "id": "smart-home-assistant",
  "name": "Smart Home Assistant",
  "version": "1.0.0",
  "description": "Smart home control with LG TV, Home Connect, Philips Hue, Tuya, and Google Home.",
  "identity": {
    "actor_types": [
      {
        "key": "homeowner",
        "label": "Homeowner",
        "description": "Smart home owner",
        "default_channel": "chat"
      }
    ],
    "admin_roles": [
      "homeowner"
    ],
    "default_actor_type": "homeowner"
  },
  "skills": [
    {
      "id": "connect-my-home",
      "name": "Connect My Home",
      "role": "gateway",
      "description": "Setup and onboarding.",
      "entry_channels": [],
      "connectors": [
        "home-assistant-mcp",
        "hue-mcp",
        "tuya-mcp",
        "google-home-mcp"
      ]
    },
    {
      "id": "home-control",
      "name": "Home Control",
      "role": "worker",
      "description": "Device control.",
      "entry_channels": [
        "chat",
        "dashboard",
        "voice"
      ],
      "connectors": [
        "home-assistant-mcp",
        "hue-mcp",
        "tuya-mcp",
        "google-home-mcp"
      ],
      "ui_capable": true
    }
  ],
  "routing": {
    "chat": {
      "default_skill": "home-control"
    },
    "dashboard": {
      "default_skill": "home-control"
    },
    "voice": {
      "default_skill": "home-control"
    }
  },
  "platform_connectors": [
    {
      "id": "home-assistant-mcp",
      "required": true,
      "description": "Home Assistant MCP with LG TV and Home Connect",
      "used_by": [
        "connect-my-home",
        "home-control"
      ],
      "ui_capable": true
    },
    {
      "id": "hue-mcp",
      "required": false,
      "description": "Philips Hue Bridge connector",
      "used_by": [
        "connect-my-home",
        "home-control"
      ]
    },
    {
      "id": "tuya-mcp",
      "required": false,
      "description": "Tuya/Smart Life IoT connector",
      "used_by": [
        "connect-my-home",
        "home-control"
      ]
    },
    {
      "id": "google-home-mcp",
      "required": false,
      "description": "Google Home/Nest SDM connector",
      "used_by": [
        "connect-my-home",
        "home-control"
      ]
    }
  ],
  "ui_plugins": [
    {
      "id": "mcp:home-assistant-mcp:home-layout-panel",
      "name": "Home Layout Panel",
      "version": "1.0.0",
      "description": "Smart home dashboard with rooms, devices, quick controls, and multi-provider status",
      "type": "ui",
      "render": {
        "mode": "adaptive",
        "iframeUrl": "/ui/home-layout-panel/1.0.0/index.html",
        "reactNative": {
          "component": "HomeLayoutPanel"
        }
      },
      "capabilities": {
        "haptics": true
      },
      "channels": [
        "command"
      ],
      "commands": []
    }
  ],
  "voice": {
    "enabled": true,
    "language": "en",
    "persona": {
      "name": "Home Assistant",
      "style": "friendly"
    },
    "welcome": "Hey! I'm your smart home assistant. What would you like to do?",
    "prompt": {
      "behaviorRules": "Execute device commands immediately without asking for confirmation. The user is the homeowner. Be concise.",
      "informationGathering": "No information gathering needed."
    },
    "verification": {
      "enabled": false
    }
  }
}