        "hue-mcp",
        "tuya-mcp",
        "google-home-mcp"
      ]
    },
    {
      "id": "home-control",
      "name": "Home Control",
      "role": "worker",
      "entry_channels": [
        "chat",
        "dashboard",
        "voice"
      ],
      "connectors": [
        "home-assistant-mcp",
        "hue-mcp",
        "tuya-mcp",
        "google-home-mcp"
      ],
      "ui_capable": true
    }
  ],
  "routing": {
    "chat": {
      "default_skill": "home-control"
    },
    "dashboard": {
