{
  "id": "smart-home-assistant",
  "name": "Smart Home Assistant",
  "version": "1.0.0",
  "description": "Smart home control.",
  "skills": [
    "connect-my-home",
    "home-control"
  ],
  "connectors": [
    "home-assistant-mcp",
    "hue-mcp",
    "tuya-mcp",
    "google-home-mcp"
  ],
  "ui_plugins": [
    {
      "id": "mcp:home-assistant-mcp:home-layout-panel",
      "name": "Home Dashboard",
      "version": "1.0.0",
      "type": "ui",
      "render": {
        "mode": "adaptive",
        "iframeUrl": "/ui/home-layout-panel/1.0.0/index.html",
        "reactNative": {
          "component": "HomeLayoutPanel"
        }
      },
      "capabilities": {
        "haptics": true
      },
      "channels": [
        "command"
      ],
      "commands": []
    },
    {
      "id": "mcp:home-assistant-mcp:whatsapp-setup",
      "name": "WhatsApp Setup",
      "version": "1.0.0",
      "type": "ui",
      "render": {
        "mode": "adaptive",
        "iframeUrl": "/ui/whatsapp-setup/1.0.0/index.html",
        "reactNative": {
          "component": "WhatsAppSetup"
        }
      },
      "capabilities": {
        "haptics": true
      },
      "channels": [
        "command"
      ],
      "commands": []
    }
  ]
}